### ENVS TO USE BFF

### APP
PROJECT_NAME=domestic-bff
PORT=3001

### MONGO DB
DATABASE_MONGO_PORT=27017
DATABASE_MONGO_HOST=database_mongo
DATABASE_MONGO_USERNAME=mongo
DATABASE_MONGO_PASSWORD=mongo1234
MONGO_URI=mongodb://database_mongo:27017/backend_database_mongo

### CACHE - REDIS
CACHE_REDIS_HOST=cache_redis
CACHE_REDIS_PORT=6379

### BACKEND API (internal — não passa pelo Kong)
API_BASE_URL=http://host.docker.internal:3000
API_TIMEOUT_MS=5000

### WebSocket
WS_CORS_ORIGINS=http://localhost:3000,http://localhost:4200

### CACHE TTLs (segundos)
CACHE_TTL_HOME=300
CACHE_TTL_SEARCH=120
CACHE_TTL_PROVIDER_PROFILE=180
CACHE_TTL_DASHBOARD=60

### SONARQUBE
SONAR_HOST_URL=http://sonarqube:9000
SONAR_TOKEN=
SONAR_PROJECT_KEY=backend-bff

### KEYCLOAK (optional for local dev)
KEYCLOAK_PORT=8081
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloak
KEYCLOAK_REALM=BACKEND
KEYCLOAK_CLIENT_ID=backend-bff
KEYCLOAK_CLIENT_SECRET=bff-client-secret
KEYCLOAK_BASE_URL=http://keycloak:8080